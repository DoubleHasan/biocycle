<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BioCycle</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="navbar">
    <div class="logo">
      <i class="fa-solid fa-leaf"></i>
      <span>BioCycle</span>
    </div>

    <nav>
      <a href="#home">Ana səhifə</a>
      <a href="#about">Haqqında</a>
      <a href="#process">Proses</a>
      <a href="#products">Məhsullar</a>
      <a href="#dashboard">Dashboard</a>
      <a href="#team">Komanda</a>
      <a href="#contact">Əlaqə</a>
    </nav>
  </header>

  <section id="home" class="hero">
    <div class="hero-content">
      <div class="hero-badge">Eco Biotechnology Startup</div>
      <h1>CO₂-ni gələcəyin davamlı protein mənbəyinə çeviririk</h1>
      <p>
        BioCycle atmosferdə və sənaye müəssisələrində yaranan karbon qazını bioreaktor texnologiyası,
        mikroorqanizmlər və ağıllı rəqəmsal sistemlər vasitəsilə protein, amin turşuları və qida əlavələrinə çevirən innovativ startup layihəsidir.
      </p>

      <div class="hero-buttons">
        <a href="#about" class="btn btn-primary">Layihə ilə tanış ol</a>
        <a href="#dashboard" class="btn btn-secondary">Dashboard-a bax</a>
      </div>

      <div class="hero-mini-stats">
        <div class="mini-card">
          <strong>1250 kg</strong>
          <span>Toplanan CO₂</span>
        </div>
        <div class="mini-card">
          <strong>340 kg</strong>
          <span>Protein çıxışı</span>
        </div>
        <div class="mini-card">
          <strong>87%</strong>
          <span>Effektivlik</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="flow-card">
        <h3>BioCycle axını</h3>

        <div class="flow-item">
          <i class="fa-solid fa-cloud"></i>
          <span>CO₂ toplanır</span>
        </div>

        <div class="flow-arrow"><i class="fa-solid fa-arrow-down"></i></div>

        <div class="flow-item">
          <i class="fa-solid fa-flask"></i>
          <span>Bioreaktora ötürülür</span>
        </div>

        <div class="flow-arrow"><i class="fa-solid fa-arrow-down"></i></div>

        <div class="flow-item">
          <i class="fa-solid fa-microchip"></i>
          <span>Mikroorqanizmlər və AI idarəsi</span>
        </div>

        <div class="flow-arrow"><i class="fa-solid fa-arrow-down"></i></div>

        <div class="flow-item highlight">
          <i class="fa-solid fa-seedling"></i>
          <span>Protein və əlavələr</span>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="section">
    <div class="section-top">
      <span class="section-tag">Layihə haqqında</span>
      <h2>BioCycle nədir?</h2>
      <p class="section-text">
        BioCycle iki böyük problemi eyni anda həll etməyə yönəlmiş startup konseptidir:
        artan CO₂ emissiyası və davamlı protein mənbələrinə ehtiyac. Layihə karbon qazını faydalı məhsula çevirərək
        həm ekoloji, həm iqtisadi, həm də texnoloji dəyər yaradır.
      </p>
    </div>
  </section>

  <section class="section section-soft">
    <div class="section-top">
      <span class="section-tag">Əsas məntiq</span>
      <h2>Problem və həll</h2>
    </div>

    <div class="grid grid-2">
      <div class="info-card">
        <div class="icon-circle problem">
          <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h3>Problem</h3>
        <p>
          Sənaye və urbanizasiya nəticəsində atmosferdə CO₂ səviyyəsi artır.
          Eyni zamanda ənənəvi protein istehsalı daha çox torpaq, su və enerji tələb edir.
        </p>
      </div>

      <div class="info-card">
        <div class="icon-circle solution">
          <i class="fa-solid fa-lightbulb"></i>
        </div>
        <h3>Həll</h3>
        <p>
          BioCycle CO₂-ni toplayır, bioreaktora ötürür, mikroorqanizmlərlə emal edir
          və nəticədə protein, amin turşuları və qida əlavələri istehsal edir.
        </p>
      </div>
    </div>
  </section>

  <section id="process" class="section">
    <div class="section-top">
      <span class="section-tag">İcra prosesi</span>
      <h2>Necə işləyir?</h2>
    </div>

    <div class="steps-grid">
      <div class="step-card">
        <div class="step-number">1</div>
        <h3>CO₂ toplanması</h3>
        <p>Karbon qazı atmosferdən və ya sənaye müəssisələrindən toplanır.</p>
      </div>

      <div class="step-card">
        <div class="step-number">2</div>
        <h3>Bioreaktor sistemi</h3>
        <p>Toplanan CO₂ idarə olunan xüsusi bioreaktor mühitinə ötürülür.</p>
      </div>

      <div class="step-card">
        <div class="step-number">3</div>
        <h3>Bioloji emal</h3>
        <p>Mikroorqanizmlər CO₂-ni zülal və digər faydalı maddələrə çevirir.</p>
      </div>

      <div class="step-card">
        <div class="step-number">4</div>
        <h3>Nəticə məhsulu</h3>
        <p>Protein tozu, amin turşuları, vitamin və qida əlavələri əldə edilir.</p>
      </div>
    </div>
  </section>

  <section id="products" class="section section-soft">
    <div class="section-top">
      <span class="section-tag">Nəticə məhsulları</span>
      <h2>Məhsullar</h2>
    </div>

    <div class="grid grid-4">
      <% products.forEach(product => { %>
        <div class="product-card">
          <div class="product-icon">
            <i class="fa-solid fa-cube"></i>
          </div>
          <h3><%= product.title %></h3>
          <p><%= product.desc %></p>
          <span class="product-label">Davamlı məhsul</span>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="section">
    <div class="section-top">
      <span class="section-tag">Üstünlüklər</span>
      <h2>Niyə BioCycle?</h2>
    </div>

    <div class="grid grid-4">
      <div class="feature-card">
        <i class="fa-solid fa-earth-europe"></i>
        <h3>CO₂ azaldılması</h3>
        <p>Karbon emissiyasının azaldılmasına birbaşa töhfə verir.</p>
      </div>

      <div class="feature-card">
        <i class="fa-solid fa-seedling"></i>
        <h3>Davamlı protein</h3>
        <p>Alternativ və ekoloji cəhətdən dayanıqlı qida mənbəyi yaradır.</p>
      </div>

      <div class="feature-card">
        <i class="fa-solid fa-chart-line"></i>
        <h3>Qeyri-neft sektoru</h3>
        <p>Azərbaycanda innovativ iqtisadi model formalaşdırmağa kömək edir.</p>
      </div>

      <div class="feature-card">
        <i class="fa-solid fa-microchip"></i>
        <h3>Texnologiya inteqrasiyası</h3>
        <p>AI, IoT və data analitika ilə proses daha ağıllı idarə olunur.</p>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="section-top">
      <span class="section-tag">Rəqəmsal tərəf</span>
      <h2>Ağıllı texnologiya inteqrasiyası</h2>
    </div>

    <div class="grid grid-3">
      <div class="tech-card">
        <div class="tech-icon"><i class="fa-solid fa-brain"></i></div>
        <h3>AI optimizasiya</h3>
        <p>İstehsal səmərəliliyi, qərar dəstəyi və prosesin optimallaşdırılması üçün istifadə olunur.</p>
      </div>

      <div class="tech-card">
        <div class="tech-icon"><i class="fa-solid fa-satellite-dish"></i></div>
        <h3>IoT monitorinq</h3>
        <p>Temperatur, qaz axını, pH və təzyiq kimi göstəricilər real vaxtda izlənir.</p>
      </div>

      <div class="tech-card">
        <div class="tech-icon"><i class="fa-solid fa-database"></i></div>
        <h3>Data analitika</h3>
        <p>Toplanan məlumatlarla məhsuldarlıq, itki və performans daha yaxşı analiz edilir.</p>
      </div>
    </div>
  </section>

  <section id="dashboard" class="section dashboard-section">
    <div class="section-top">
      <span class="section-tag dark-tag">Canlı görünüş</span>
      <h2>Demo Dashboard</h2>
    </div>

    <div class="grid grid-4">
      <div class="stat-card">
        <span>Toplanan CO₂</span>
        <strong><%= stats.co2 %> kg</strong>
      </div>

      <div class="stat-card">
        <span>Protein istehsalı</span>
        <strong><%= stats.protein %> kg</strong>
      </div>

      <div class="stat-card">
        <span>Effektivlik</span>
        <strong><%= stats.efficiency %>%</strong>
      </div>

      <div class="stat-card">
        <span>Temperatur</span>
        <strong><%= stats.temperature %>°C</strong>
      </div>

      <div class="stat-card">
        <span>pH göstəricisi</span>
        <strong><%= stats.ph %></strong>
      </div>

      <div class="stat-card">
        <span>Təzyiq</span>
        <strong><%= stats.pressure %> bar</strong>
      </div>

      <div class="stat-card">
        <span>Sensor statusu</span>
        <strong>Aktiv</strong>
      </div>

      <div class="stat-card">
        <span>AI vəziyyəti</span>
        <strong>Online</strong>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="section-top">
      <span class="section-tag">İnkişaf planı</span>
      <h2>Roadmap</h2>
    </div>

    <div class="roadmap-list">
      <% roadmap.forEach((item, index) => { %>
        <div class="roadmap-item">
          <div class="roadmap-index">0<%= index + 1 %></div>
          <div class="roadmap-content">
            <h3>Faza <%= index + 1 %></h3>
            <p><%= item %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <section id="team" class="section">
    <div class="section-top">
      <span class="section-tag">Komanda</span>
      <h2>Layihə üzvləri</h2>
    </div>

    <div class="grid grid-2">
      <% team.forEach(member => { %>
        <div class="team-card">
          <div class="avatar-circle"><%= member.name.charAt(0) %></div>
          <h3><%= member.name %></h3>
          <p><%= member.role %></p>
        </div>
      <% }) %>
    </div>
  </section>

  <section id="contact" class="section contact-section">
    <div class="contact-wrapper">
      <div class="contact-info">
        <span class="section-tag">Əlaqə</span>
        <h2>Bizimlə əlaqə saxlayın</h2>
        <p>
          BioCycle barədə daha çox məlumat almaq, tərəfdaşlıq imkanlarını müzakirə etmək
          və ya layihə ilə bağlı fikir bildirmək üçün formu doldurun.
        </p>

        <div class="contact-points">
          <div><i class="fa-solid fa-envelope"></i> biocycle@example.com</div>
          <div><i class="fa-solid fa-location-dot"></i> Bakı, Azərbaycan</div>
          <div><i class="fa-solid fa-leaf"></i> Eco-Biotech Innovation</div>
        </div>
      </div>

      <form action="/contact" method="POST" class="contact-form">
        <input type="text" name="name" placeholder="Adınız" required>
        <input type="email" name="email" placeholder="Email ünvanınız" required>
        <textarea name="message" rows="6" placeholder="Mesajınızı yazın..." required></textarea>
        <button type="submit" class="btn btn-primary">Mesaj göndər</button>
      </form>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-logo">
      <i class="fa-solid fa-leaf"></i>
      <span>BioCycle</span>
    </div>
    <p>© 2026 BioCycle. Dayanıqlı gələcək üçün innovativ həll.</p>
  </footer>

</body>
</html>